[gd_scene load_steps=2 format=3 uid="uid://b1discordsocialdemo0"]

[ext_resource type="Script" path="res://main.gd" id="1_main"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_main")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Discord Social SDK — Demo"
horizontal_alignment = 1

[node name="InitRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="AppIdLabel" type="Label" parent="Margin/VBox/InitRow"]
layout_mode = 2
text = "Application ID:"

[node name="AppIdEdit" type="LineEdit" parent="Margin/VBox/InitRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Your Discord application ID"

[node name="InitButton" type="Button" parent="Margin/VBox/InitRow"]
layout_mode = 2
text = "Initialize"

[node name="AuthRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="AuthorizeButton" type="Button" parent="Margin/VBox/AuthRow"]
layout_mode = 2
text = "Authorize (open browser)"

[node name="TokenRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="TokenEdit" type="LineEdit" parent="Margin/VBox/TokenRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "…or paste an OAuth2 access token"

[node name="ConnectTokenButton" type="Button" parent="Margin/VBox/TokenRow"]
layout_mode = 2
text = "Connect with token"

[node name="StatusLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "Status: Disconnected"

[node name="UserLabel" type="Label" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
text = "User: —"

[node name="PresenceSep" type="HSeparator" parent="Margin/VBox"]
layout_mode = 2

[node name="PresenceRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="DetailsEdit" type="LineEdit" parent="Margin/VBox/PresenceRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Details (e.g. In a match)"

[node name="StateEdit" type="LineEdit" parent="Margin/VBox/PresenceRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "State (e.g. Round 3)"

[node name="SetPresenceButton" type="Button" parent="Margin/VBox/PresenceRow"]
layout_mode = 2
text = "Set presence"

[node name="ClearPresenceButton" type="Button" parent="Margin/VBox/PresenceRow"]
layout_mode = 2
text = "Clear"

[node name="FriendRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2

[node name="FriendEdit" type="LineEdit" parent="Margin/VBox/FriendRow"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Username to friend"

[node name="SendFriendButton" type="Button" parent="Margin/VBox/FriendRow"]
layout_mode = 2
text = "Send friend request"

[node name="DisconnectButton" type="Button" parent="Margin/VBox"]
layout_mode = 2
text = "Disconnect"

[node name="LogPanel" type="PanelContainer" parent="Margin/VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="LogText" type="RichTextLabel" parent="Margin/VBox/LogPanel"]
unique_name_in_owner = true
layout_mode = 2
bbcode_enabled = true
scroll_following = true

[connection signal="pressed" from="Margin/VBox/InitRow/InitButton" to="." method="_on_initialize_pressed"]
[connection signal="pressed" from="Margin/VBox/AuthRow/AuthorizeButton" to="." method="_on_authorize_pressed"]
[connection signal="pressed" from="Margin/VBox/TokenRow/ConnectTokenButton" to="." method="_on_connect_token_pressed"]
[connection signal="pressed" from="Margin/VBox/PresenceRow/SetPresenceButton" to="." method="_on_set_presence_pressed"]
[connection signal="pressed" from="Margin/VBox/PresenceRow/ClearPresenceButton" to="." method="_on_clear_presence_pressed"]
[connection signal="pressed" from="Margin/VBox/FriendRow/SendFriendButton" to="." method="_on_send_friend_request_pressed"]
[connection signal="pressed" from="Margin/VBox/DisconnectButton" to="." method="_on_disconnect_pressed"]
